{
    "name": "laravel/laravel",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^8.3",
        "ext-json": "*",
        "barryvdh/laravel-ide-helper": "^3.5",
        "google/apiclient": "^2.6",
        "guzzlehttp/guzzle": "^7.2",
        "knplabs/github-api": "^3.3",
        "laravel/framework": "^12.0",
        "laravel/tinker": "^2.10",
        "league/flysystem-aws-s3-v3": "^3.0",
        "markwalet/laravel-packagist": "^v1.1",
        "nyholm/psr7": "^1.4|^2.0",
        "pda/pheanstalk": "^5.0",
        "pusher/pusher-php-server": "^7.0",
        "spatie/laravel-dashboard": "^4.0",
        "spatie/laravel-dashboard-belgian-trains-tile": "^4.0",
        "spatie/laravel-dashboard-calendar-tile": "^4.0",
        "spatie/laravel-dashboard-oh-dear-uptime-tile": "^4.0",
        "spatie/laravel-dashboard-time-weather-tile": "^4.0",
        "spatie/laravel-dashboard-velo-tile": "^4.0",
        "spatie/laravel-google-calendar": "^3.5",
        "spatie/laravel-ignition": "^2.0",
        "spatie/laravel-tail": "^4.4",
        "spatie/laravel-webhook-client": "^3.5",
        "spatie/last-fm-now-playing": "^1.0",
        "spatie/valuestore": "^1.2"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9.1",
        "laravel/boost": "^2.3",
        "laravel/envoy": "^2.8",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^11.0",
        "spatie/laravel-ray": "^1.33"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "format": [
            "vendor/bin/php-cs-fixer fix"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ]
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    }
}
